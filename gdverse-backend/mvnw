# ----------------------------------------------------------------------------
# Maven Wrapper Startup Script for Unix
# ----------------------------------------------------------------------------

DIRNAME=`dirname "$0"`
APP_HOME=`cd "$DIRNAME" && pwd`

# Find Java
if [ -n "$JAVA_HOME" ] ; then
    JAVA_EXE="$JAVA_HOME/bin/java"
else
    JAVA_EXE="java"
fi

WRAPPER_JAR="$APP_HOME/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$APP_HOME/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
    mkdir -p "$APP_HOME/.mvn/wrapper"
    echo "Downloading Maven Wrapper Jar..."
    if command -v curl >/dev/null 2>&1; then
        curl -sL -o "$WRAPPER_JAR" "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
    elif command -v wget >/dev/null 2>&1; then
        wget -q -O "$WRAPPER_JAR" "https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
    else
        echo "ERROR: curl or wget is required to download Maven Wrapper."
        exit 1
    fi
fi

if [ ! -f "$WRAPPER_JAR" ]; then
    echo "ERROR: Failed to download maven-wrapper.jar"
    exit 1
fi

exec "$JAVA_EXE" -jar "$WRAPPER_JAR" "$@"
